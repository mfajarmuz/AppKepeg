# Supabase Postgres
# IMPORTANT: URL-encode password if it contains special chars.
# Examples: @ -> %40, # -> %23, * -> %2A
#
# Runtime (Transaction Pooler, 6543)
DATABASE_URL="postgresql://postgres.<project-ref>:<URL_ENCODED_PASSWORD>@aws-1-<region>.pooler.supabase.com:6543/postgres?schema=public"

# Direct connection (5432) — recommended for Prisma migrate/DDL
DATABASE_URL_DIRECT="postgresql://postgres:<URL_ENCODED_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?schema=public"

# Auth
AUTH_SECRET="change-me"
